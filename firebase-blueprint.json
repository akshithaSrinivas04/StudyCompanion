{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores student profile information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "goals": { "type": "string" },
        "studyStreak": { "type": "integer" },
        "totalXp": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Note": {
      "title": "Study Note",
      "description": "Represents a student's uploaded notes and AI-generated content.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string", "description": "Extracted text from the note" },
        "summary": { "type": "string" },
        "explanation": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "A quiz generated from a specific note.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "noteId": { "type": "string" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "string" },
              "explanation": { "type": "string" }
            }
          }
        },
        "score": { "type": "integer" },
        "totalQuestions": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "noteId", "questions"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Collection of study notes."
    },
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Collection of generated quizzes."
    }
  }
}
